# HUGGING_FACE_TOKEN: Required for Hugging Face Inference API.
# Users should get this from https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN="MY_HF_TOKEN"

# GEMINI_API_KEY: Required for Gemini AI API calls (fallback).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Access to 50+ models via OpenRouter
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
